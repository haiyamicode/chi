struct Sheep {
    AnimalBase animal...;

    func new(int id) {
        this.animal = {id};
    }

    func talk() {
        print("baaaaahh {}\n", this.get_id());
    }
};

struct Dog {
    AnimalBase animal...;

    func new(int id) {
        this.animal = {id};
    }

    func get_id() int {
        return -this.animal.id;
    }

    func talk() {
        print("wuff wuff {}\n", this.get_id());
    }
};

struct Cat {
    Animal animal...;

    func get_id() int {
        return 0;
    }

    func talk() {
        print("meeoooww {}\n", this.get_id());
    }
};

trait Animal {
    func get_id() int;
    func talk() {}
}

struct AnimalBase {
    Animal animal...;
    int id;

    func new(int id) {
        this.id = id;
    }

    func get_id() int {
        return this.id;
    }
};

func main() {
    Cat cat = {};
    Animal animal = &cat;
    animal.talk();

    Sheep sheep = {1};
    Sheep sheep2 = {2};
    animal = &sheep;
    animal.talk();
    animal = &sheep2;
    animal.talk();

    Dog dog = {3};
    animal = &dog;
    animal.talk();
}