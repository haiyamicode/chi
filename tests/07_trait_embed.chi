struct Sheep {
    base ...AnimalBase;

    func new(id int) {
        this.base = {id};
    }

    func make_sound() {
        printf("baaaaahh {}\n", this.get_id());
    }
};

struct Dog {
    base ...AnimalBase;

    func new(id int) {
        this.base = {id};
    }

    func get_id() int {
        return -this.base.id;
    }

    func make_sound() {
        printf("wuff wuff {}\n", this.get_id());
    }
};

struct Cat: Animal {
    func get_id() int {
        return 0;
    }

    func make_sound() {
        printf("meeoooww {}\n", this.get_id());
    }
};

trait Animal {
    func get_id() int;
    func make_sound() {}
}

struct AnimalBase: Animal {
    id int;

    func new(id int) {
        this.id = id;
    }

    func get_id() int {
        return this.id;
    }
};

func main() {
    var cat Cat = {};
    var animal &Animal;
    animal = &cat;
    animal.make_sound();

    var sheep Sheep = {1};
    var sheep2 Sheep = {2};
    animal = &sheep;
    animal.make_sound();
    animal = &sheep2;
    animal.make_sound();

    var dog Dog = {3};
    animal = &dog;
    animal.make_sound();
}