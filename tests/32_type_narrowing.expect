-- Basic narrowing --
basic_positive(5)=6
basic_positive(null)=-1
basic_guard(5)=6
basic_guard(null)=-1
basic_assert(5)=6

-- Compound && positive --
and_positive(1,2)=3
and_positive(null,2)=-1
and_positive(1,null)=-1
and_positive(null,null)=-1
and_positive_mixed(3,"hello")=8
and_positive_mixed(null,"hello")=-1
and_three(1,2,3)=6
and_three(1,null,3)=-1

-- Compound || guard --
or_guard(3,4)=7
or_guard(null,4)=-1
or_guard(3,null)=-1
or_guard_three(1,2,3)=6
or_guard_three(null,2,3)=-1

-- Negated && guard --
negated_and_guard(5,6)=11
negated_and_guard(null,6)=-1
negated_and_guard(5,null)=-1
negated_and_guard_three(1,2,3)=6
negated_and_guard_three(1,null,3)=-1

-- Assert compound --
assert_and(10,20)=30
assert_and_three(1,2,3)=6

-- Mixed with bool --
and_with_bool(5,true)=10
and_with_bool(5,false)=-1
and_with_bool(null,true)=-1
guard_or_with_bool(5,true)=10
guard_or_with_bool(5,false)=-1
guard_or_with_bool(null,true)=-1

-- Sequential guards --
sequential_guards(1,2)=3
sequential_guards(null,2)=-1
sequential_guards(1,null)=-2

-- And with else branch --
and_else_branch(3,7)=sum=10
and_else_branch(null,7)=missing

-- Double negation --
double_negation(5)=6
double_negation(null)=-1

-- Guard with block --
guard_block(3,4)=7
  (guard: returning -1)
guard_block(null,4)=-1

-- String narrowing --
narrow_string("World","Hello")=Hello World
narrow_string(null,"Hello")=???
narrow_string("World",null)=???

-- Presence operators --
truthiness_and(1,2)=true
truthiness_and(0,2)=true
truthiness_and(null,2)=false
truthiness_and(1,null)=false
truthiness_or(1,2)=true
truthiness_or(0,null)=true
truthiness_or(null,2)=true
truthiness_or(null,null)=false

-- Narrowing alias: destructible types --
read_only:
  construct(1)
  read: 1
  destroy(1)
reassign:
  construct(10)
  before: 10
  destroy(10)
  construct(20)
  after: 20
  destroy(20)
guard_read:
  construct(100)
  guard read: 100
  destroy(100)
guard_reassign:
  construct(200)
  before: 200
  destroy(200)
  construct(300)
  after: 300
  destroy(300)
assert_reassign:
  construct(400)
  before: 400
  destroy(400)
  construct(500)
  after: 500
  destroy(500)
compound:
  construct(1000)
  construct(2000)
  a=1000 b=2000
  destroy(2000)
  destroy(1000)
null_case:
  null case done

-- DotExpr narrowing --
dot_positive=43
dot_guard=null
dot_assert=100
dot_compound=10 hello
dot_compound_guard=5 world
  construct(42)
positive:
  positive: 42
  destroy(42)
  construct(100)
guard:
  guard: 100
  destroy(100)
null positive:
  positive: null
null guard:
  guard: null
  construct(200)
assert:
  assert: 200
  destroy(200)
