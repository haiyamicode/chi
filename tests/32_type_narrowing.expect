-- Basic narrowing --
basic_positive(5)=6
basic_positive(null)=-1
basic_guard(5)=6
basic_guard(null)=-1
basic_assert(5)=6

-- Compound && positive --
and_positive(1,2)=3
and_positive(null,2)=-1
and_positive(1,null)=-1
and_positive(null,null)=-1
and_positive_mixed(3,"hello")=8
and_positive_mixed(null,"hello")=-1
and_three(1,2,3)=6
and_three(1,null,3)=-1

-- Compound || guard --
or_guard(3,4)=7
or_guard(null,4)=-1
or_guard(3,null)=-1
or_guard_three(1,2,3)=6
or_guard_three(null,2,3)=-1

-- Negated && guard --
negated_and_guard(5,6)=11
negated_and_guard(null,6)=-1
negated_and_guard(5,null)=-1
negated_and_guard_three(1,2,3)=6
negated_and_guard_three(1,null,3)=-1

-- Assert compound --
assert_and(10,20)=30
assert_and_three(1,2,3)=6

-- Mixed with bool --
and_with_bool(5,true)=10
and_with_bool(5,false)=-1
and_with_bool(null,true)=-1
guard_or_with_bool(5,true)=10
guard_or_with_bool(5,false)=-1
guard_or_with_bool(null,true)=-1

-- Sequential guards --
sequential_guards(1,2)=3
sequential_guards(null,2)=-1
sequential_guards(1,null)=-2

-- And with else branch --
and_else_branch(3,7)=sum=10
and_else_branch(null,7)=missing

-- Double negation --
double_negation(5)=6
double_negation(null)=-1

-- Guard with block --
guard_block(3,4)=7
  (guard: returning -1)
guard_block(null,4)=-1

-- String narrowing --
narrow_string("World","Hello")=Hello World
narrow_string(null,"Hello")=???
narrow_string("World",null)=???

-- Truthiness operators --
truthiness_and(1,2)=true
truthiness_and(null,2)=false
truthiness_and(1,null)=false
truthiness_or(1,2)=true
truthiness_or(null,2)=true
truthiness_or(null,null)=false
