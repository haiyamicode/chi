const WORLD = "world";
const ID1 = -1;
const ID2 = ID1 + 1;
const ID3 = (ID2 + 1) << 5;

func world() string {
    return WORLD;
}

func main() {
    print("hello {} {}\n", "the", world());
    any id = world();
    print("hello {}\n", id);
    print("hello {}\n", ID1);
    id = ID2;
    print("hello {}, {}, {}\n", ID1, id, ID3);
}