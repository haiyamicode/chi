struct Node {
    int id;
    func new(int id) { this.id = id; }
};

func f(optional<Node*> node, bool force) {
    if (node) {
        print("has value: node.id == {}\n", node.id);
    } else {
        print("has no value, !node == {}\n", !node);
    }
    if (force) {
        print("forced print: node!.id == {}\n", node!.id);
    }
}

func main() {
    Node a = {1};
    f(&a, false);
    f(&a, true);
    f({}, false);
}