-- Basic destructuring --
x=1 y=2

-- Rename --
a=10 b=20

-- Nested --
x=3 y=4 label=hello

-- Deep nested --
x=5 y=6 label=deep id=42

-- Spread copy --
p2.x=1 p2.y=2

-- Spread override --
p2.x=10 p2.y=2

-- Spread string --
n2.name=hello n2.value=99
n.name=hello n.value=42

-- Spread all override --
p2.x=100 p2.y=200

-- Destructure string --
name=world value=7
n.name=world n.value=7

-- Let destructure --
x=50 y=60

-- Lifecycle: destructure from var --
Traced(1) created
Traced(2) created
before destructure
Traced(1) copied
Traced(2) copied
Traced(1) copied
Traced(2) copied
a.id=1 b.id=2
block exit
Traced(2) destroyed
Traced(1) destroyed
Traced(2) destroyed
Traced(1) destroyed
after block
pair.a.id=1 pair.b.id=2
func exit
Traced(2) destroyed
Traced(1) destroyed

-- Lifecycle: spread --
Traced(10) created
Traced(20) created
before spread
Traced(10) copied
Traced(30) created
p1.a.id=10 p1.b.id=20
p2.a.id=10 p2.b.id=30
func exit
Traced(30) destroyed
Traced(10) destroyed
Traced(20) destroyed
Traced(10) destroyed

