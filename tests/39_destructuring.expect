-- Cross spread: basic --
e.x=42 e.name=hello e.y=10 e.z=20
b.x=42 b.name=hello

-- Cross spread: defaults --
e.x=7 e.name=world e.y=0 e.z=0

-- Cross spread: override --
e.x=1 e.name=new e.y=5 e.z=6
b.name=old

-- Cross spread: lifecycle --
Traced(99) created
before cross spread
Traced(99) copied
te.t.id=99 te.name=base te.extra=42
tb.t.id=99 tb.name=base
func exit
Traced(99) destroyed
Traced(99) destroyed

-- Cross spread: discard --
b.x=1 b.name=hello
e.x=1 e.name=hello e.y=10 e.z=20

-- Cross spread: discard override --
b.x=1 b.name=new

-- Cross spread: discard lifecycle --
Traced(77) created
before spread
Traced(77) copied
tb.t.id=77 tb.name=big
te.t.id=77 te.name=big te.extra=42
func exit
Traced(77) destroyed
Traced(77) destroyed

