struct Bar {
    int id = 0;
    void new(int id) { this.id = id; }
    void delete() {
        printf("delete bar {}\n", this.id);
    }
};

struct Foo {
    int id;
    Bar bar1;
    Bar bar2;
    void new(int id) {
        this.id = id;
        this.bar1.id = id * 10 + 1;
        this.bar2.id = id * 10 + 2;
    }
    void delete() {
        printf("delete foo {}\n", this.id);
    }
};

int main() {
    array<Bar> arr;
    arr.add({-1});
    arr.add({-2});
    arr.add({-3});
    arr.add({-4});
    Foo foo1 = {1};
    if (1 == 1) {
        Foo foo2 = {2};
        return 0;
    }
    Foo foo3 = {3};
    return 0;
}