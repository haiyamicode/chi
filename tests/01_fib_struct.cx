func main() {
    Fib fib = {12};
    print("fib: {}\n", fib.calculate());
}

struct Fib {
    int n;

    func new(int n) {
        this.n = n;
    }

    func calculate() int {
        return this.fib(this.n);
    }

    func fib(int n) int {
        int x;
        if (n < 2) {
            return n;
        }
        return this.fib(n - 2) + this.fib(n - 1);
    }
};