func main() {
    var fib Fib = {12};
    printf("fib: {}\n", fib.calculate());
}

struct Fib {
    n int;

    func calculate() int {
        return this.fib(this.n);
    }

    func fib(n int) int {
        if n < 2 {
            return n;
        }
        return this.fib(n - 2) + this.fib(n - 1);
    }
}