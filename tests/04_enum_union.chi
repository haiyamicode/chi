enum Key {
    Enter = 1,
    Space,
    Ctrl = 10,
    Alt,
    Delete
}

struct KeyCombination {
    key Key;
    modifier Key;
}

enum KeyStrokeType {
    Single,
    Combination
}

union KeyStrokeData {
    single Key;
    combination KeyCombination;
}

struct KeyStroke {
    type KeyStrokeType;
    data KeyStrokeData;
}

func print_key(key Key) {
    if key == Key.Enter {
        printf("Enter ({})", key);
    } else if key == Key.Ctrl {
        printf("Ctrl ({})", key);
    } else {
        printf("unhandled key ({})", key);
    }
}

func print_keystroke(ks KeyStroke) {
    if ks.type == KeyStrokeType.Single {
        printf("single: ", 0);
        print_key(ks.data.single);
    }
    else if ks.type == KeyStrokeType.Combination {
        printf("combination: {{key: ", 0);
        print_key(ks.data.combination.key);
        printf(", modifier: ", 0);
        print_key(ks.data.combination.modifier);
        printf("}} ", 0);
    }
    printf("\n", 0);
}

func main() {
    printf("enter_key_value: {}\n", Key.Enter);
    printf("space_key_value: {}\n", Key.Space);
    var key Key = 12;
    printf("key_value: {}\n", key);
    if key == Key.Delete {
        printf("delele_key: {}\n", key);
    }

    var ks1 KeyStroke;
    ks1.data.single = Key.Enter;
    ks1.type = KeyStrokeType.Single;
    print_keystroke(ks1);

    var ks2 KeyStroke;
    ks2.data.combination.key = Key.Enter;
    ks2.data.combination.modifier = Key.Ctrl;
    ks2.type = KeyStrokeType.Single;
    print_keystroke(ks2);
    ks2.type = KeyStrokeType.Combination;
    print_keystroke(ks2);
    print_key(Key.Alt);
}