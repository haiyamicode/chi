struct Node<any T> {
    T data;
    Node<T>* next = 0;
    func new(T data) {
        this.data = data;
    }
};

struct LinkedList<any T> {
    Node<T>* head = 0;
    Node<T>* tail = 0;
    int size = 0;

    func add(T value) Node<T>* {
        this.tail = new {value};
        if (!this.head) {
            this.head = this.tail;
        } else {
            let node = this.head;
            for (;;) {
                if (!node.next) {
                    break;
                }
                node = node.next;
            }
            node.next = this.tail;
        }
        ++this.size;
        return this.tail;
    }
}

func main() {
    LinkedList<int> list = {};
    list.add(1);
    printf("list.size: {}\n", list.size);
    list.add(2);
    list.add(3);
    printf("list.size: {}\n", list.size);
    for (let node=list.head; node; node = node.next) {
        printf("item value: {}\n", node.data);
    }
}