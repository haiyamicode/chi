struct Node<T> {
    data T;
    next *Node<T> = 0;

    static func new(data T): Node<T> {
        return Node<T>{data};
    }
}

struct LinkedList<T> {
    head *Node<T> = 0;
    tail *Node<T> = 0;
    size int = 0;

    func add(value T) *T {
        this.tail = new {data};
        if !this.head {
            this.head = this.tail;
        } else {
            var node = this.head;
            for {
                if !node.next {
                    break;
                }
                node = node.next;
            }
            node.next = this.tail;
        }
        this.size++;
        return &this.tail.data;
    }

    func delete() {
        var node = this.head;
        for {
            var next = node.next;
            delete node;
            if !next {
                break;
            }
            node = next;
        }
    }
}

func main() {
    var list LinkedList<int> = {};
    printf("add item: {}\n", list.add(1));
    printf("list.size: {}\n", list.size);
    printf("add item: {}\n", list.add(2));
    printf("add item: {}\n", list.add(3));
    printf("list.size: {}\n", list.size);
    for var node = list.head; node; node = node.next {
        printf("item value: {}\n", node.data);
    }
}