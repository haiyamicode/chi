enum Parse<T, E> {
    Ok(T),
    Error(E)
}

struct Wrap {
    result: Parse<int, string>;
}

struct Point {
    x: int;
    y: int;

    mut func new(x: int, y: int) {
        this.x = x;
        this.y = y;
    }
}

struct PointWrap {
    point: Point;
}

func accept_parse(value: Parse<int, string>) {}

func accept_point(value: Point) {}

func make_ok() Parse<int, string> {
    return Ok{1};
}

func make_point() Point {
    return {1, 2};
}

func main() {
    var direct: Parse<int, string> = Ok{1};
    var wrap = Wrap{result: Error{"field"}};
    accept_parse(Ok{2});
    var arr: Array<Parse<int, string>> = [Ok{3}, Error{"array"}];

    var picked = switch direct {
        Ok => Parse<int, string>.Ok{10},
        Error => Parse<int, string>.Error{"bad"}
    };

    var point = {3, 4};
    var point_wrap = PointWrap{point: {5, 6}};
    accept_point({7, 8});
    var point_arr: Array<Point> = [{9, 10}, {11, 12}];
    var maybe_point: ?Point = Point{13, 14};
}
