test_null_coalescing:
a ?? 0 = 42
b ?? 99 = 99
fallback point = (0, 0)
inferred fallback point = (0, 0)

test_construct_operand_postfix:
maybe ?? field = true
true && field = true
true && method = true

test_optional_chain_field:
p?.x = 10
q?.y = null

test_optional_chain_method:
p?.sum() = 7
q?.sum() = null

test_chaining:
p?.x ?? -1 = 100
q?.y ?? -1 = -1

test_null_comparison:
a != null: true
b == null: true
null == b: true
null != a: true
p != null: true
q == null: true

test_optional_presence:
null: falsy
?false: truthy
?true: truthy
null: falsy
?0: truthy
?42: truthy
?Point(0,0): truthy
?null Point: falsy

test_if_let:
let point=(10, 20)
let null else
maybe_point(true)
if let expr sum=16
maybe_point(false)
if let expr miss=-1
var point mutated=(11, 22)
let destructure=(3, 4)
var destructure mutated=(15, 16)
maybe_point(true)
if let destructure expr=16
field binding mutated=(31, 32)
field destructure=(31, 32)

test_if_let_zero:
let zero=0
if let zero expr=10

test_if_let_enum_pattern:
enum tuple=42
enum struct=(3, 4)
enum expr=55
enum miss=-1
enum second struct=(5, 6)
enum field=(7, 8)

