struct Foo {
    a int;
}

struct Bar {
    foo Foo;
}

func inc(ref *int) {
    ref!++;
}

func main() {
    var b int = -2019;
    printf("b: {}\n", b);
    inc(*b);
    printf("b after inc: {}\n", b);
    printf("b after inc == -2018: {}\n", b == -2018);
    printf("(b.(int8) + 1).(int): {}\n", (b.(int8) + 1).(int));

    var p *void = 0;
    var bar1 Bar;
    bar1.foo.a = b;
    p = *bar1.foo;
    var foo_cpy Foo = p.(*Foo)!;
    printf("foo_cpy.a: {}\n", foo_cpy.a);
    printf("p.(*int)!: {}\n", p.(*int)!);
}