struct Node {
    id int;
    func new(id int) { this.id = id; }
};

func f(node ?(&Node), force bool) {
    if node {
        printf("has value: node.id == {}\n", node.id);
    } else {
        printf("has no value, !node == {}\n", !node);
    }
    if force {
        printf("forced print: node!.id == {}\n", node!.id);
    }
}

func main() {
    var a Node = {1};
    f(&a, false);
    f(&a, true);
    f({}, false);
}