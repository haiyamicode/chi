Test 1: Basic inference
apply_int(5, n => n * 2) = 10

Test 2: Multiple params
combine(10, 20, (x, y) => x + y) = 30

Test 3: Explicit return, inferred params
apply_int(7, n => n * 2) = 14

Test 4: Char type
apply_char('a', to_upper) = 'A'

Test 5: Transform with inference
transform_int(6, x => x * x) = 36

Test 6: Bool return
filter_positive(42, n => n > 0) = 42
filter_positive(-5, n => n > 0) = 0

Test 7: Void return
for_each got: 100

Test 8: Mixed explicit/inferred
apply_int(3, n: int => n + 10) = 13

Test 9: Arrow syntax
apply_int(4, func(n) => n * 3) = 12

Test 10: Arrow multiple params
combine(5, 7, func(x, y) => x * y) = 35

Test 11: Arrow explicit params
apply_int(8, func(n: int) => n + 100) = 108

Test 12: Arrow bool return
filter_positive(10, func(n) => n > 5) = 10

Test 13: Return type inference
make_wrapper inferred T=int from return type: 42

Test 14: String type inference
make_wrapper inferred T=string from return type: hello

Test 15: Lambda returning struct
lambda returning struct: Point(10, 20)

Test 16: Struct return type inference
make_wrapper inferred T=Point: Point(30, 40)

Test 17: Array.filter
filter evens from [1,2,3,4,5,6]: 2 4 6

Test 18: Array.map
map *2 on [1,2,3,4,5,6]: 2 4 6 8 10 12

Test 19: Array.map returning struct
map to Points: (1,10) (2,20) (3,30) (4,40) (5,50) (6,60)

All lambda inference tests passed!
