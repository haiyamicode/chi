=== basic dispatch ===
1: baaaaahh
2: meeoooww
3: <silence>
=== heap + delete ===
circle: area=75
rect: area=12
Circle.delete(r=5)
Rect.delete(3x4)
circle: area=243
Circle.delete(r=9)
=== function params ===
circle: area=300
rect: area=42
bigger: circle
Rect.delete(6x7)
Circle.delete(r=10)
=== sizeof ===
sizeof &Shape: 16
sizeof Circle: 4
sizeof Rect: 8
Rect.delete(1x1)
Circle.delete(r=1)
=== Box<Shape> ===
circle: area=147
rect: area=6
before cleanup:
Rect.delete(2x3)
Circle.delete(r=7)
=== multi-interface dispatch ===
direct: Widget(btn) size=42
desc: Widget(btn)
measure: 42
ref desc: Widget(btn)
ref measure: 42
=== type switch ===
circle r=8
rect 5x3
sheep: sheep
cat: cat
ant: other
Rect.delete(5x3)
Circle.delete(r=8)
=== default methods ===
person greet: Hello, Alice!
person shout: Hello, Alice!!!
robot greet: Beep, I am R2D2
robot shout: Beep, I am R2D2!!
alien greet: Hello, Zorg!
alien shout: Zorg says GREETINGS
ref person greet: Hello, Alice!
ref person shout: Hello, Alice!!!
ref robot greet: Beep, I am R2D2
ref robot shout: Beep, I am R2D2!!
ref alien greet: Hello, Zorg!
ref alien shout: Zorg says GREETINGS
fn person: Hello, Alice!
fn robot: Beep, I am R2D2
fn alien shout: Zorg says GREETINGS
=== default + multi-interface ===
label: [sword]
desc: Item(sword)
ref label: [sword]
ref desc: Item(sword)
=== interface embedding ===
greet: Hello from Bob
bye: Goodbye from Bob
ref greet: Hello from Bob
ref bye: Goodbye from Bob
generic polite: Hello from Bob, Goodbye from Bob
=== multi-level embedding ===
id: 42
name: hero
info: Entity(42, hero)
ref id: 42
ref name: hero
ref info: Entity(42, hero)
generic entity: #42: hero - Entity(42, hero)
=== struct embedding ===
doubled: 10
add: 8
val: 5
overridden doubled: 30
inherited add: 10
deep doubled: 8
deep add: 10
adder d: 105
adder deep: 104
=== ops composite interfaces ===
sum_three int: 60
sum_three float: 7
bitwise_and int: 15
