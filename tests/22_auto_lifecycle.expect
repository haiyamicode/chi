=== Test 1: Auto-destroy without custom delete ===
Outer1.new
  Inner1.new(1)
Before function exit
  Inner1.delete(1)
After helper returned

=== Test 2: __new initializes defaults before user's new() ===
WithDefaults.new: a=10, b=20, setting c=30
Final: a=10, b=20, c=30

=== Test 3: Destruction order (reverse of declaration) ===
OrderedContainer.new
  OrderedField.new('first')
  OrderedField.new('second')
  OrderedField.new('third')
Before function exit
OrderedContainer.delete (user)
  OrderedField.delete('third')
  OrderedField.delete('second')
  OrderedField.delete('first')
After helper returned

=== Test 4: Shared<T> field auto-destruction ===
HoldsShared.new
  RefCountedData.new(42)
  ref_count after construction: 1
Before function exit
  RefCountedData.delete(42)
After helper - RefCountedData should be deleted

=== Test 5: Nested auto-destruction (3 levels) ===
Before function exit
Level1.delete(1)
  Level2.delete(10)
    Level3.delete(100)
After helper returned

=== Test 6: Optional<Shared<T>> field auto-destruction ===
HoldsOptionalShared.new
  OptionalData.new(99)
  ref_count: 1
Before function exit (with value)
  OptionalData.delete(99)
After helper - OptionalData should be deleted
Before function exit (null)
After null helper - no crash expected

=== Test 7: Optional<T> with direct struct ===
HoldsOptionalDirect.new
  DirectStruct.new(77)
Before function exit
  DirectStruct.delete(77)
After helper - DirectStruct should be deleted

=== Test 8: Both __new and __delete on same struct ===
BothLifecycles.new: default_val=999
  Inner1.new(88)
Before function exit
  Inner1.delete(88)
After helper returned

=== Test 9: Multiple local variables destruction order ===
  TrackedVar.new('first')
  TrackedVar.new('second')
  TrackedVar.new('third')
Before function exit - destroys in reverse declaration order
  TrackedVar.delete('third')
  TrackedVar.delete('second')
  TrackedVar.delete('first')
After helper returned

=== Test 10: Temporary cleanup (no leaks) ===
--- fn call arg ---
  TrackedVar.new('fn-arg')
  TrackedVar.delete('fn-arg')
after consume(make())
--- nested fn call arg ---
  TrackedVar.new('nested')
  TrackedVar.delete('nested')
after consume(identity(make()))
--- orphaned fn call ---
  TrackedVar.new('orphan-fn')
after orphaned make()
--- orphaned construct expr ---
  TrackedVar.new('orphan-construct')
after orphaned TrackedVar construct
--- if expr as fn arg ---
  TrackedVar.new('if-true')
  TrackedVar.delete('if-true')
after consume(if ...)
--- early return before later stmt-temp ---
after early(true)
  TrackedVar.new('late-temp')
  TrackedVar.delete('late-temp')
after early(false)
  TrackedVar.delete('orphan-construct')
  TrackedVar.delete('orphan-fn')
=== Test 11: Temps in expression-position contexts ===
--- if condition: DotExpr base on temp ---
  TrackedVar.new('if-cond')
if matched
after if
--- while condition: DotExpr base on temp ---
  TrackedVar.new('while-cond')
after while
--- for post: orphaned temp ---
in for loop
  TrackedVar.new('for-post')
after for
--- unary op on temp ---
  TrackedVar.new('unary')
unary not-empty matched
after unary
  TrackedVar.delete('unary')
  TrackedVar.delete('for-post')
  TrackedVar.delete('while-cond')
  TrackedVar.delete('if-cond')
=== Test 12: Function arg copy semantics ===
--- named var to fn ---
  TrackedVar.new('named')
  TrackedVar.copy('named')
  TrackedVar.delete('named')
  after consume: t.name='named'
--- move to fn ---
  TrackedVar.new('moved')
  TrackedVar.delete('moved')
  after consume(move)
--- named var to constructor ---
  TrackedVar.new('ctor-named')
  TrackedVar.copy('ctor-named')
  TrackedVar.copy('ctor-named')
  TrackedVar.delete('ctor-named')
  c.inner.name='ctor-named', t3.name='ctor-named'
--- rvalue to constructor ---
  TrackedVar.new('ctor-rvalue')
  TrackedVar.copy('ctor-rvalue')
  TrackedVar.delete('ctor-rvalue')
  c2.inner.name='ctor-rvalue'
--- move to constructor ---
  TrackedVar.new('ctor-moved')
  TrackedVar.copy('ctor-moved')
  TrackedVar.delete('ctor-moved')
  c3.inner.name='ctor-moved'
  after move-construct
--- multiple args ---
  TrackedVar.new('arg-a')
  TrackedVar.new('arg-b')
  TrackedVar.copy('arg-a')
  TrackedVar.copy('arg-b')
  consumed 'arg-a' and 'arg-b'
  TrackedVar.delete('arg-b')
  TrackedVar.delete('arg-a')
  after: a='arg-a', b='arg-b'
--- multiple rvalue args ---
  TrackedVar.new('rv-a')
  TrackedVar.new('rv-b')
  consumed 'rv-a' and 'rv-b'
  TrackedVar.delete('rv-b')
  TrackedVar.delete('rv-a')
  after consume_two(make(), make())
--- named var in loop ---
  TrackedVar.new('loop-0')
  TrackedVar.copy('loop-0')
  TrackedVar.delete('loop-0')
  TrackedVar.delete('loop-0')
  TrackedVar.new('loop-1')
  TrackedVar.copy('loop-1')
  TrackedVar.delete('loop-1')
  TrackedVar.delete('loop-1')
  after loop
--- scope exit ---
  TrackedVar.delete('arg-b')
  TrackedVar.delete('arg-a')
  TrackedVar.delete('ctor-moved')
  TrackedVar.delete('ctor-rvalue')
  TrackedVar.delete('ctor-named')
  TrackedVar.delete('ctor-named')
  TrackedVar.delete('named')
=== Test 13: Method by-value param cleanup ===
--- regular method ---
  TrackedVal.new(10)
  TrackedVal.new(5)
  TrackedVal.copy(5)
  TrackedVal.combine(10, 5)
  TrackedVal.new(15)
  TrackedVal.delete(5)
  c.id=15
--- operator method (a + b) ---
  TrackedVal.new(20)
  TrackedVal.new(7)
  TrackedVal.add(20, 7)
  TrackedVal.new(27)
  f.id=27
--- void method ---
  TrackedVal.new(30)
  TrackedVal.new(8)
  TrackedVal.copy(8)
  TrackedVal.absorb(30, 8)
  TrackedVal.delete(8)
  after absorb
--- multi-param method ---
  TrackedVal.new(1)
  TrackedVal.new(2)
  TrackedVal.new(3)
  TrackedVal.copy(2)
  TrackedVal.copy(3)
  TrackedVal.merge(1, 2, 3)
  TrackedVal.new(6)
  TrackedVal.delete(3)
  TrackedVal.delete(2)
  l.id=6
--- compound assignment (+=) ---
  TrackedVal.new(100)
  TrackedVal.new(50)
  TrackedVal.add(100, 50)
  TrackedVal.new(150)
  TrackedVal.delete(100)
  m.id=150
--- chained operators ---
  TrackedVal.new(1)
  TrackedVal.new(2)
  TrackedVal.new(3)
  TrackedVal.add(1, 2)
  TrackedVal.new(3)
  TrackedVal.add(3, 3)
  TrackedVal.new(6)
  s.id=6
--- rvalue to method ---
  TrackedVal.new(40)
  TrackedVal.new(9)
  TrackedVal.combine(40, 9)
  TrackedVal.new(49)
  TrackedVal.delete(9)
  u.id=49
--- scope exit ---
  TrackedVal.delete(49)
  TrackedVal.delete(40)
  TrackedVal.delete(6)
  TrackedVal.delete(3)
  TrackedVal.delete(2)
  TrackedVal.delete(1)
  TrackedVal.delete(50)
  TrackedVal.delete(150)
  TrackedVal.delete(6)
  TrackedVal.delete(3)
  TrackedVal.delete(2)
  TrackedVal.delete(1)
  TrackedVal.delete(8)
  TrackedVal.delete(30)
  TrackedVal.delete(27)
  TrackedVal.delete(7)
  TrackedVal.delete(20)
  TrackedVal.delete(15)
  TrackedVal.delete(5)
  TrackedVal.delete(10)
