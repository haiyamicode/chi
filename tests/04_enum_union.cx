enum Key {
    Enter = 1,
    Space,
    Ctrl = 10,
    Alt,
    Delete
};

struct KeyCombination {
    Key key;
    Key modifier;
};

enum KeyStrokeType {
    Single,
    Combination
};

union KeyStrokeData {
    Key single;
    KeyCombination combination;
};

struct KeyStroke {
    KeyStrokeType type;
    KeyStrokeData data;
};

void print_key(Key key) {
    if (key == Key.Enter) {
        print("Enter ({})", key);
    }
    else if (key == Key.Ctrl) {
        print("Ctrl ({})", key);
    } else {
        print("unhandled key ({})", key);
    }
}

void print_keystroke(KeyStroke ks) {
    if (ks.type == KeyStrokeType.Single) {
        print("single: ", 0);
        print_key(ks.data.single);
    }
    else if (ks.type == KeyStrokeType.Combination) {
        print("combination: {{key: ", 0);
        print_key(ks.data.combination.key);
        print(", modifier: ", 0);
        print_key(ks.data.combination.modifier);
        print("}} ", 0);
    }
    print("\n", 0);
}

int main() {
    print("enter_key_value: {}\n", Key.Enter);
    print("space_key_value: {}\n", Key.Space);
    Key key = 12;
    print("key_value: {}\n", key);
    if (key == Key.Delete) {
        print("delele_key: {}\n", key);
    }

    KeyStroke ks1;
    ks1.data.single = Key.Enter;
    ks1.type = KeyStrokeType.Single;
    print_keystroke(ks1);

    KeyStroke ks2;
    ks2.data.combination.key = Key.Enter;
    ks2.data.combination.modifier = Key.Ctrl;
    ks2.type = KeyStrokeType.Single;
    print_keystroke(ks2);
    ks2.type = KeyStrokeType.Combination;
    print_keystroke(ks2);
    print_key(Key.Alt);
    return 0;
}