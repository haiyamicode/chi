struct Data {
    int id;

    void new(int id) {
        this.id = id;
    }

    void delete() {
        print("destroy data id={}\n", this.id);
    }
};

int main() {
    array<box<Data>> a;
    a.add({1});
    a.add({2});
    a.add({3});
    let v = a[1];
    print("a[0]: id={}\n", a[0].id);
    print("a[1]: id={}\n", a[1].id);
    print("a[2]: id={}\n", a[2].id);
    let b = a;
    a.add({4});
    print("a[3]: id={}\n", a[3].id);
    print("a.size={}, b.size={}\n", a.size, b.size);
    print("b[0]: id={}\n", b[0].id);
    print("b[1]: id={}\n", b[1].id);
    print("b[2]: id={}\n", b[2].id);
    return 0;
}