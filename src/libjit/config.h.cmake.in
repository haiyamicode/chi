/* The number of bytes in type char */
#define SIZEOF_CHAR ${SIZEOF_CHAR}

/* The number of bytes in type double */
#define SIZEOF_DOUBLE ${SIZEOF_DOULE}

/* The number of bytes in type float */
#define SIZEOF_FLOAT ${SIZEOF_FLOAT}

/* The number of bytes in type int */
#define SIZEOF_INT ${SIZEOF_INT}

/* The number of bytes in type long */
#define SIZEOF_LONG ${SIZEOF_LONG}

/* The number of bytes in type long double */
#define SIZEOF_LONG_DOUBLE ${SIZEOF_LONG_DOULE} SIZEOF_DOUBLE

/* The number of bytes in type long long */
#define SIZEOF_LONG_LONG ${SIZEOF_LONG_LONG}

/* The number of bytes in type short */
#define SIZEOF_SHORT ${SIZEOF_SHORT}

/* The number of bytes in type void * */
#define SIZEOF_VOID_P ${SIZEOF_VOID_P}

/* The number of bytes in type __int64 */
#define SIZEOF___INT64 ${SIZEOF___INT64} 0

