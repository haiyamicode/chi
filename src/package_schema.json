{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chi Package Configuration",
  "description": "Schema for package.jsonc configuration files in Chi projects",
  "type": "object",
  "required": ["entry_file"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Package name"
    },
    "include": {
      "type": "array",
      "description": "Additional files, directories, or glob patterns to include when installing package sources",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "version": {
      "type": "string",
      "description": "Package version"
    },
    "entry_file": {
      "type": "string",
      "description": "The main entry file for the package",
      "minLength": 1
    },
    "c_interop": {
      "type": "object",
      "description": "Configuration for C interoperability",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether C interop is enabled",
          "default": false
        },
        "include_directories": {
          "type": "array",
          "description": "List of include directories for C compilation",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "source_files": {
          "type": "array",
          "description": "List of C source file patterns to compile",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "link_libraries": {
          "type": "array",
          "description": "List of libraries to link against",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "library_paths": {
          "type": "array",
          "description": "List of library search paths for linking",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "native_modules": {
          "type": "object",
          "description": "Native C modules imported via libclang",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "includes": {
                "type": "array",
                "items": {"type": "string"},
                "description": "C header files to import"
              },
              "symbols": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Symbols to import (filter)"
              },
              "include_paths": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Additional include directories"
              },
              "link": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Libraries to link"
              },
              "pkg_config": {
                "type": "string",
                "description": "pkg-config package name"
              }
            }
          }
        }
      },
      "additionalProperties": false,
      "if": {
        "properties": {
          "enabled": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "source_files": {
            "minItems": 1
          }
        }
      }
    }
  },
  "additionalProperties": false
}
